{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++ Build (C++23)",
            "type": "shell",
            "command": "D:\\mingw64\\bin\\g++.exe",
            "args": [
                "-std=c++23",
                "-O2",
                "-Wall",
                "-Wextra",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
